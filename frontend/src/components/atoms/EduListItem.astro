---
const { title, period } = Astro.props;
---

<li
  class="flex items-start justify-between gap-4 pb-4 border-b border-border last:border-0 last:pb-0"
>
  <div class="font-medium text-foreground/90">{title}</div>
  <div class="text-xs font-mono text-muted-foreground whitespace-nowrap">
    {period}
  </div>
</li>
