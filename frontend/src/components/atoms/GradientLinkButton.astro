---
import ArrowUpRight from "../../icons/ArrowUpRightIcon.astro";

const { href, text } = Astro.props;
---

<a
  href={href}
  class="hidden md:inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-full gradient-primary text-primary-foreground shadow-soft hover:shadow-glow transition-smooth"
>
  {text}
  <ArrowUpRight class="h-3.5 w-3.5" />
</a>
