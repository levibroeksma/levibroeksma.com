---
// Props
const { text, highlighted = false } = Astro.props;
---

<span
  class={!highlighted
    ? "text-xs px-3 py-1.5 rounded-full bg-secondary border border-border"
    : "text-xs font-mono px-2.5 py-1 rounded-md bg-primary-foreground/10 border border-primary-foreground/20"}
>
  {text}
</span>
