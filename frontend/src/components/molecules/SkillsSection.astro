---
import skills from "../../data/skills.json";
import languages from "../../data/languages.json";
import education from "../../data/education.json";
import trainings from "../../data/trainings.json";
import { skills as skillsI18n } from "@data/i18n.json";

import { getLangFromPathname } from "@lib/utils/i18n.js";
const lang = getLangFromPathname(Astro.url.pathname) || "nl";

/* Icons */
import Languages from "../../icons/LanguagesIcon.astro";
import Code from "../../icons/CodeIcon.astro";
import Database from "../../icons/DatabaseIcon.astro";
import Cloud from "../../icons/CloudIcon.astro";
import Wrench from "../../icons/WrenchIcon.astro";
import GraduationCap from "../../icons/GraduationCapIcon.astro";
---

<section id="skills" class="section-pad">
  <div class="container mx-auto">
    <div class="mb-16">
      <div class="text-xs font-mono uppercase tracking-widest text-accent mb-3">
        {skillsI18n[lang].label}
      </div>
      <h2
        class="font-display text-4xl md:text-5xl font-medium leading-tight max-w-2xl"
      >
        {skillsI18n[lang].title}<span class="text-accent">.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        [
          {
            icon: Code,
            title: skillsI18n[lang].categories.languages,
            items: skills.languages,
          },
          {
            icon: Database,
            title: skillsI18n[lang].categories.databases,
            items: skills.databases,
          },
          {
            icon: Cloud,
            title: skillsI18n[lang].categories.cloud,
            items: skills.cloud,
          },
          {
            icon: Wrench,
            title: skillsI18n[lang].categories.tools,
            items: skills.tools,
          },
        ].map(({ icon: Icon, title, items }) => (
          <div class="rounded-2xl border border-border bg-card p-6 hover:shadow-soft transition-smooth">
            <div class="flex items-center gap-3 mb-5">
              <div class="h-10 w-10 rounded-xl gradient-primary text-primary-foreground flex items-center justify-center shadow-soft">
                <Icon class="h-5 w-5" />
              </div>
              <h3 class="font-display text-lg font-semibold">{title}</h3>
            </div>
            <ul class="space-y-2">
              {items.map((it) => (
                <li class="text-sm text-foreground/80 flex items-start gap-2">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-accent shrink-0" />
                  {it}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    {/* Languages + Education */}
    <div class="mt-16 grid lg:grid-cols-2 gap-5">
      <div class="rounded-2xl border border-border bg-card p-8">
        <div class="flex items-center gap-3 mb-6">
          <Languages class="h-5 w-5 text-accent" />
          <h3 class="font-display text-2xl font-semibold">
            {skillsI18n[lang].languagesTitle}
          </h3>
        </div>
        <div class="space-y-5">
          {
            languages.map((l) => (
              <div>
                <div class="flex justify-between items-baseline mb-2">
                  <div class="font-medium">{l.name}</div>
                  <div class="text-xs font-mono text-muted-foreground">
                    {l.level}
                  </div>
                </div>
                <div class="h-1.5 rounded-full bg-secondary overflow-hidden">
                  <div
                    class="h-full gradient-primary rounded-full transition-smooth"
                    style={{ width: `${l.pct}%` }}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-border bg-card p-8">
        <div class="flex items-center gap-3 mb-6">
          <GraduationCap class="h-5 w-5 text-accent" />
          <h3 class="font-display text-2xl font-semibold">
            {skillsI18n[lang].educationTitle}
          </h3>
        </div>
        <ul class="space-y-4">
          {
            education.map((e) => (
              <li class="flex items-start justify-between gap-4 pb-4 border-b border-border last:border-0 last:pb-0">
                <div class="font-medium text-foreground/90">{e.title}</div>
                <div class="text-xs font-mono text-muted-foreground whitespace-nowrap">
                  {e.period}
                </div>
              </li>
            ))
          }
        </ul>
        <div class="mt-6 pt-6 border-t border-border">
          <div
            class="text-xs font-mono uppercase tracking-widest text-muted-foreground mb-3"
          >
            {skillsI18n[lang].trainingsTitle}
          </div>
          <div class="flex flex-wrap gap-2">
            {
              trainings.map((t) => (
                <span class="text-xs px-3 py-1.5 rounded-full bg-secondary border border-border">
                  {t}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
