---
import Location from "../../icons/LocationIcon.astro";
import Mail from "../../icons/MailIcon.astro";
import ArrowUpRight from "../../icons/ArrowUpRightIcon.astro";
import i18n from "@data/i18n.json";
const { locale = "nl" } = Astro.props;
const { contact } = i18n[locale as keyof typeof i18n] ?? i18n.nl;
---

<section id="contact" class="section-pad">
  <div class="container mx-auto">
    <div
      class="rounded-3xl gradient-primary text-primary-foreground p-10 md:p-16 shadow-elegant relative overflow-hidden"
    >
      <div
        class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-accent/30 blur-3xl"
        aria-hidden
      >
      </div>
      <div class="relative grid md:grid-cols-12 gap-10 items-end">
        <div class="md:col-span-7">
          <div
            class="text-xs font-mono uppercase tracking-widest mb-3 text-white"
          >
            {contact.label}
          </div>
          <h2
            class="font-display text-4xl md:text-6xl font-medium leading-[1.05] text-white"
          >
            {contact.title}<span class="text-accent">.</span>
          </h2>
          <p class="mt-5 max-w-lg leading-relaxed text-white">
            {contact.description}
          </p>
        </div>
        <div class="md:col-span-5 space-y-3">
          <a
            href={`mailto:${contact.emailValue}`}
            class="flex items-center gap-4 p-4 rounded-xl bg-primary-foreground/5 hover:bg-primary-foreground/10 border border-primary-foreground/10 transition-smooth group"
          >
            <Mail class="h-5 w-5 text-accent shrink-0" />
            <div class="min-w-0">
              <div class="text-xs uppercase tracking-wider text-white">
                {contact.emailLabel}
              </div>
              <div class="font-medium truncate text-white">
                {contact.emailValue}
              </div>
            </div>
            <ArrowUpRight
              class="h-4 w-4 ml-auto opacity-0 group-hover:opacity-100 transition-smooth"
            />
          </a>
          <div
            class="flex items-center gap-4 p-4 rounded-xl bg-primary-foreground/5 border border-primary-foreground/10"
          >
            <Location class="h-5 w-5 text-accent shrink-0" />
            <div>
              <div class="text-xs uppercase tracking-wider text-white">
                {contact.addressLabel}
              </div>
              <div class="font-medium text-white">
                {contact.addressValue}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
