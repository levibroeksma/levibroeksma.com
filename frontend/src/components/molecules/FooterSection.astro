---
// Components

// Data
import { footer } from "@data/i18n.json";

// Utils
import { getLangFromPathname } from "@lib/utils/i18n.js";

// Constants
const lang = getLangFromPathname(Astro.url.pathname) || "nl";
const year = new Date().getFullYear();
---

<footer class="py-5 border-t border-border">
  <div
    class="container mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted-foreground"
  >
    <div class="font-display">
      <span class="text-accent">© </span>
      {year}
      {footer[lang].copyrightName}
    </div>
    <div class="font-mono text-xs">{footer[lang].tagline}</div>
  </div>
</footer>
