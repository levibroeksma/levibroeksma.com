---
// Components
import Tag from "@atoms/Tag.astro";

// Props
const { data, index, length } = Astro.props;

// Utils
import { getLangFromPathname } from "@lib/utils/i18n.js";

// Constants
const lang = getLangFromPathname(Astro.url.pathname) || "nl";
---

<article
  class="group relative rounded-2xl border border-border bg-background p-6 md:p-8 hover:border-primary/30 hover:shadow-soft transition-smooth"
>
  <div class="grid md:grid-cols-12 gap-6 md:gap-8">
    <div class="md:col-span-3">
      <div class="font-mono text-xs text-muted-foreground">
        {String(index + 1).padStart(2, "0")} /
        {length.toString().padStart(2, "0")}
      </div>
      <h3
        class="font-display text-2xl md:text-3xl font-semibold mt-2 leading-tight"
      >
        {data.title[lang]}
      </h3>
      <div class="mt-2 text-sm text-muted-foreground">
        {data.org[lang]}
      </div>
      <div class="mt-1 text-xs font-mono text-accent">
        {data.period}
      </div>
    </div>
    <div class="md:col-span-9 space-y-4">
      <p class="text-foreground/85 leading-relaxed">
        {data.description[lang]}
      </p>
      <div class="flex flex-wrap gap-2">
        {data.stack.map((t) => <Tag text={t} />)}
      </div>
    </div>
  </div>
</article>
