---
import "../styles/global.css";
import NavSection from "../components/molecules/NavSection.astro";
import FooterSection from "../components/molecules/FooterSection.astro";
import { getLangFromPathname } from "@lib/utils/i18n.js";
import themeScript from "@lib/utils/theme.js?raw";

const { noindex } = Astro.props;
const lang = getLangFromPathname(Astro.url.pathname) || "nl";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />
    <title>Levi Broeksma — Fullstack ingenieur</title>
    <meta
      name="description"
      content="CV van Levi Broeksma — Fullstack ingenieur met passie voor kwaliteit, detail en schaalbare software."
    />
    <meta name="author" content="Levi Broeksma" />
    <script is:inline set:html={themeScript}></script>
  </head>
  <body>
    <NavSection />
    <main>
      <slot />
    </main>
    <FooterSection />
  </body>
</html>
